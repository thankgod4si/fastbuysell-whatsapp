# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=any_secret_string_you_choose
WHATSAPP_FLOW_ID=your_flow_id_from_meta_dashboard

# Resend (email)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Fast Buy & Sell <hello@yourdomain.com>

# Vercel Cron Protection (set same value in Vercel project env vars)
CRON_SECRET=any_secret_string_you_choose
