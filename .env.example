# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Echoes AI Booking Engine ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...your_openai_key

# Sofi Payment Integration (trysofi.co)
SOFI_API_BASE_URL=https://api.trysofi.co
SOFI_API_KEY=your_sofi_api_key
SOFI_WEBHOOK_SECRET=your_sofi_webhook_signing_secret

# Public app URL (used for payment callback_url)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=any_secret_string_you_choose
WHATSAPP_FLOW_ID=1013920171185557

# Resend (email)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Fast Buy & Sell <hello@yourdomain.com>

# Vercel Cron Protection (set same value in Vercel project env vars)
CRON_SECRET=any_secret_string_you_choose
